---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { getCollection, render } from "astro:content";

import PostLink from "@/components/PostLink";

import DocumentLayout from "@/layouts/DocumentLayout";

import { getFormattedDate } from "@/utils/dates";

export const getStaticPaths = (async () => {
	const posts = await getCollection("blog");
	return posts.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}) satisfies GetStaticPaths;

export const prerender = true;

export type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const postHeadings = headings.filter((h) => h.depth === 2);

const socialImage = entry.data.ogImage ?? `/og/${entry.id}.png`;
const articleDate = entry.data.publishDate.toISOString();
---

<script>
	document.addEventListener("astro:page-load", () => {
		const scrollBtn =
			(document.getElementById("to-top-btn") as HTMLButtonElement) || null;
		const targetHeader =
			(document.getElementById("blog-hero") as HTMLDivElement) || null;

		if (!scrollBtn || !targetHeader) return;

		function callback(entries: IntersectionObserverEntry[]) {
			entries.forEach((entry) => {
				// only show the scroll to top button when the heading is out of view
				scrollBtn.dataset.show = (!entry.isIntersecting).toString();
			});
		}

		scrollBtn.addEventListener("click", () => {
			document.documentElement.scrollTo({ top: 0, behavior: "smooth" });
		});

		const observer = new IntersectionObserver(callback);
		observer.observe(targetHeader);
	});
</script>

<DocumentLayout
	meta={{
		article: {
			...entry,
			data: {
				...entry.data,
				ogImage: socialImage,
			},
		},
	}}
>
	<div id="blog-hero">
		{
			entry.data.draft && (
				<blockquote
					class="bg-primary/30 text-foreground my-8 rounded py-4 pl-4"
					role="alert"
				>
					This post is a <strong>draft</strong>. If you're reading this, you're
					privy to the secret link. Please <strong>don't share</strong> it with
					anyone.
				</blockquote>
			)
		}
		<h1
			class="mb-4 text-2xl font-medium tracking-tight text-balance"
			transition:name={`post-${entry.id}-title`}
		>
			{entry.data.title}
		</h1>
		<time
			class="text-foreground/90 mb-2 block"
			datetime={articleDate}
			transition:name={`post-${entry.id}-date`}
			>{getFormattedDate(entry.data.publishDate)}</time
		>
		<p class="mb-10">
			{entry.data.description}
		</p>
	</div>
	<article class="relative">
		{
			postHeadings.length > 0 && (
				<aside class="prose prose-blog xl:prose-sm prose-a:font-normal prose-a:no-underline w-full xl:absolute xl:left-full xl:h-full xl:max-w-[38ch]">
					<nav class="w-full py-2 xl:sticky xl:top-0 xl:pr-4 xl:pl-6">
						<p>In this article</p>
						<ul id="toc-list">
							{postHeadings.map((heading) => (
								<li
									class="group focus-within:text-primary hover:text-primary data-[active='true']:text-primary transition-all duration-200"
									data-active="false"
								>
									<a href={`#${heading.slug}`}>{heading.text}</a>
								</li>
							))}
						</ul>
					</nav>
				</aside>
			)
		}
		<div
			class="prose prose-blog prose-headings:scroll-mt-4 prose-headings:text-lg prose-headings:font-semibold prose-h1:text-2xl prose-h2:text-xl prose-h3:text-lg prose-th:before:content-none [&_div[data-remark-code-title]+pre]:border-primary [&_div[data-remark-code-title]]:border-primary [&_div[data-remark-code-title]]:bg-primary-foreground [&_div[data-remark-code-title]]:text-primary mb-10 [&_div[data-remark-code-title]]:mt-6 [&_div[data-remark-code-title]]:rounded-t [&_div[data-remark-code-title]]:border-t [&_div[data-remark-code-title]]:border-r [&_div[data-remark-code-title]]:border-l [&_div[data-remark-code-title]]:px-4 [&_div[data-remark-code-title]]:py-1.5 [&_div[data-remark-code-title]]:text-sm [&_div[data-remark-code-title]]:font-medium [&_div[data-remark-code-title]+pre]:mt-0 [&_div[data-remark-code-title]+pre]:rounded-t-none [&_div[data-remark-code-title]+pre]:border-r [&_div[data-remark-code-title]+pre]:border-b [&_div[data-remark-code-title]+pre]:border-l [&>u]:underline-offset-4"
		>
			<Content components={{ a: PostLink }} />
		</div>
	</article>
</DocumentLayout>
<button
	id="to-top-btn"
	class="border-foreground bg-foreground text-background hover:border-secondary hover:bg-secondary hover:text-foreground focus-visible:border-secondary focus-visible:bg-secondary focus-visible:text-foreground fixed end-4 bottom-8 z-90 flex h-12 w-12 translate-y-28 items-center justify-center rounded-full border-2 text-3xl opacity-0 shadow-lg outline-hidden transition-all duration-300 focus-within:outline-hidden focus-visible:outline-hidden data-[show=true]:translate-y-0 data-[show=true]:opacity-100 sm:end-8"
	aria-label="Back to Top"
	data-show="false"
	><svg
		xmlns="http://www.w3.org/2000/svg"
		aria-hidden="true"
		focusable="false"
		fill="none"
		viewBox="0 0 24 24"
		stroke-width="2"
		stroke="currentColor"
		class="size-5"
	>
		<path
			stroke-linecap="round"
			stroke-linejoin="round"
			d="M4.5 15.75l7.5-7.5 7.5 7.5"></path>
	</svg>
</button>
<script>
	// Table of Contents
	function setupToc() {
		const observer = new IntersectionObserver(function (entries) {
			entries.forEach((entry) => {
				const id = entry.target.getAttribute("id");

				const activeAnchor = document.querySelector(
					`#toc-list li a[href="#${id}"]`,
				);
				const parent = activeAnchor?.parentElement;
				if (!parent) return;

				parent.dataset.active = entry.intersectionRatio > 0 ? "true" : "false";
			});
		});

		document.querySelectorAll("h2[id], h3[id]").forEach((heading) => {
			observer.observe(heading);
		});
	}

	document.addEventListener("astro:page-load", setupToc);
	window.addEventListener("resize", setupToc);
</script>
<script>
	// Reader progess indicator
	// The markup is in the DocumentLayout.astro file
	const progressContainerEl = document.querySelector(
		"#reader-progess-bar-container",
	) as HTMLElement | null;

	function updateScrollProgressBar() {
		if (!progressContainerEl) return;

		const windowScroll =
			document.body.scrollTop || document.documentElement.scrollTop;
		const height =
			document.documentElement.scrollHeight -
			document.documentElement.clientHeight;

		const scrolled = Math.round((windowScroll / height) * 100);

		progressContainerEl.style.setProperty("--progess-width", `${scrolled}%`);
	}

	window.addEventListener("scroll", updateScrollProgressBar);
	document.addEventListener("astro:page-load", updateScrollProgressBar);
</script>
